{
  "name": "Simple Dark",
  "colors": {
    "editor.foreground": "#D4D4D4",
    "editor.background": "#1E1E1E"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#6A9955",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#B5CEA8"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#9CDCFE"
      }
    }
  ]
}
