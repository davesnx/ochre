(documentation
 (package ochre))

(rule
 (alias doc-markdown)
 (enabled_if %{bin-available:odoc})
 (mode
  (promote (until-clean)))
 (deps %{workspace_root}/_doc/_markdown/ochre/README.md)
 (targets README.md)
 (action
  (system
   "printf '<!-- Please do not edit this file directly. Update README.mld instead. -->\\n\\n' > %{targets} && tail -n +2 %{workspace_root}/_doc/_markdown/ochre/README.md >> %{targets}")))
